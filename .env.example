# Copy to your env file (AGENT_ENV_FILE points at it) or export these directly.
# Keep real values out of git.

# --- Paths (all optional; defaults shown) ---
AGENT_VAULT_DIR = "~/vault"                              # markdown vault + db.sqlite live here
AGENT_ENV_FILE = "~/.config/ai-ops-agent/secrets.env"    # where the MCP server reads provider keys
AGENT_RUNTIME_DIR = "~/.agent-runtime"                   # your agent runtime's config + session logs (dashboard reads this)
AGENT_GATEWAY_UNIT = "agent-gateway"                     # systemd user unit the dashboard monitors
AGENT_GATEWAY_PORT = "18789"                             # port the gateway listens on

# --- Provider key (default: OpenAI; see scripts/models.py to switch providers) ---
OPENAI_API_KEY = ""       # chat, vision, OCR, image generation, and embeddings

# Optional alternative providers (only used if you point models.py at them)
GLM_API_KEY = ""          # z.ai (OpenAI-compatible chat / vision)
DEEPSEEK_API_KEY = ""     # DeepSeek (a cheap chat tier)
